# ICMP Ping Sweep Detection
alert icmp any any -> $HOME_NET any (msg:"ICMP Ping Sweep Detected"; \
  itype:8; threshold:type both, track by_src, count 10, seconds 2; \
  sid:1000001; rev:1; classtype:network-scan;)

# ICMP Flood Detection
alert icmp any any -> $HOME_NET any (msg:"ICMP Flood Attack Detected"; \
  itype:8; threshold:type both, track by_src, count 100, seconds 5; \
  sid:1000002; rev:1; classtype:denial-of-service;)

# Large ICMP Packet Detection
alert icmp any any -> $HOME_NET any (msg:"Large ICMP Packet Detected"; \
  itype:8; dsize:>1024; \
  sid:1000003; rev:1; classtype:network-scan;)

# TCP SYN Port Scan
alert tcp any any -> $HOME_NET any (msg:"TCP SYN Port Scan Detected"; \
  flags:S; threshold:type both, track by_src, count 20, seconds 3; \
  sid:1000010; rev:1; classtype:network-scan;)

# NULL Scan Detection
alert tcp any any -> $HOME_NET any (msg:"TCP NULL Scan Detected"; \
  flags:0; \
  sid:1000011; rev:1; classtype:network-scan;)

# XMAS Scan Detection
alert tcp any any -> $HOME_NET any (msg:"TCP XMAS Scan Detected"; \
  flags:FPU; \
  sid:1000012; rev:1; classtype:network-scan;)

# FIN Scan Detection
alert tcp any any -> $HOME_NET any (msg:"TCP FIN Scan Detected"; \
  flags:F; \
  sid:1000013; rev:1; classtype:network-scan;)

# UDP Port Scan Detection
alert udp any any -> $HOME_NET any (msg:"UDP Port Scan Detected"; \
  threshold:type both, track by_src, count 20, seconds 3; \
  sid:1000014; rev:1; classtype:network-scan;)
  
# SSH Brute Force Attack
alert tcp any any -> $HOME_NET 22 (msg:"SSH Brute Force Attempt Detected"; \
  flags:S; threshold:type both, track by_src, count 5, seconds 60; \
  sid:1000020; rev:1; classtype:attempted-admin;)

# SSH Login Failure
alert tcp any any -> $HOME_NET 22 (msg:"SSH Login Failure Detected"; \
  content:"SSH"; offset:0; depth:3; \
  threshold:type both, track by_src, count 3, seconds 60; \
  sid:1000021; rev:1; classtype:attempted-admin;)

# SSH Version Scanner
alert tcp any any -> $HOME_NET 22 (msg:"SSH Version Scanner Detected"; \
  content:"SSH-"; offset:0; depth:4; \
  sid:1000022; rev:1; classtype:network-scan;)
  
# SQL Injection Attempt
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"HTTP SQL Injection Attempt"; \
  content:"SELECT"; http_uri; nocase; \
  content:"FROM"; http_uri; nocase; \
  sid:1000030; rev:1; classtype:web-application-attack;)

# Cross-Site Scripting (XSS) Attempt
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"HTTP XSS Attempt Detected"; \
  content:"<script>"; http_uri; nocase; \
  sid:1000031; rev:1; classtype:web-application-attack;)

# Directory Traversal Attempt
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"HTTP Directory Traversal Attempt"; \
  content:"../"; http_uri; \
  sid:1000032; rev:1; classtype:web-application-attack;)

# HTTP Command Injection
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"HTTP Command Injection Attempt"; \
  content:"/etc/passwd"; http_uri; nocase; \
  sid:1000033; rev:1; classtype:web-application-attack;)

# Suspicious HTTP User Agent
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"Suspicious HTTP User Agent Detected"; \
  content:"sqlmap"; http_header; nocase; \
  sid:1000034; rev:1; classtype:web-application-attack;)

# HTTP Nikto Scanner
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"Nikto Web Scanner Detected"; \
  content:"Nikto"; http_header; nocase; \
  sid:1000035; rev:1; classtype:network-scan;)
  
# DNS Amplification Attack
alert udp any any -> $HOME_NET 53 (msg:"DNS Amplification Attack Detected"; \
  threshold:type both, track by_src, count 50, seconds 5; \
  sid:1000040; rev:1; classtype:denial-of-service;)

# DNS Zone Transfer Attempt
alert tcp any any -> $HOME_NET 53 (msg:"DNS Zone Transfer Attempt Detected"; \
  content:"|00 FC|"; offset:2; depth:2; \
  sid:1000041; rev:1; classtype:attempted-recon;)

# Excessive DNS Queries
alert udp any any -> $HOME_NET 53 (msg:"Excessive DNS Queries Detected"; \
  threshold:type both, track by_src, count 100, seconds 10; \
  sid:1000042; rev:1; classtype:network-scan;)
  
# FTP Brute Force
alert tcp any any -> $HOME_NET 21 (msg:"FTP Brute Force Attempt Detected"; \
  content:"USER"; nocase; \
  threshold:type both, track by_src, count 5, seconds 30; \
  sid:1000050; rev:1; classtype:attempted-admin;)

# FTP Anonymous Login Attempt
alert tcp any any -> $HOME_NET 21 (msg:"FTP Anonymous Login Attempt"; \
  content:"USER anonymous"; nocase; \
  sid:1000051; rev:1; classtype:policy-violation;)

# FTP Bounce Attack
alert tcp any any -> $HOME_NET 21 (msg:"FTP Bounce Attack Detected"; \
  content:"PORT"; nocase; offset:0; depth:4; \
  sid:1000052; rev:1; classtype:network-scan;)
  
# TCP SYN Flood
alert tcp any any -> $HOME_NET any (msg:"TCP SYN Flood Detected"; \
  flags:S; threshold:type both, track by_src, count 200, seconds 5; \
  sid:1000060; rev:1; classtype:denial-of-service;)

# UDP Flood
alert udp any any -> $HOME_NET any (msg:"UDP Flood Attack Detected"; \
  threshold:type both, track by_src, count 500, seconds 5; \
  sid:1000061; rev:1; classtype:denial-of-service;)

# HTTP GET Flood
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"HTTP GET Flood Detected"; \
  content:"GET"; http_method; \
  threshold:type both, track by_src, count 200, seconds 5; \
  sid:1000062; rev:1; classtype:denial-of-service;)
  
# Suspicious Outbound IRC Traffic (Botnet C2)
alert tcp $HOME_NET any -> any 6667 (msg:"Suspicious IRC Outbound Traffic - Possible Botnet"; \
  content:"PRIVMSG"; nocase; \
  sid:1000070; rev:1; classtype:trojan-activity;)

# Metasploit Meterpreter Detection
alert tcp any any -> $HOME_NET any (msg:"Possible Meterpreter Session Detected"; \
  content:"|fc e8 82 00 00 00|"; \
  sid:1000071; rev:1; classtype:trojan-activity;)

# Suspicious PowerShell Download
alert tcp $HOME_NET any -> any $HTTP_PORTS (msg:"Suspicious PowerShell Download Cradle Detected"; \
  content:"powershell"; http_uri; nocase; \
  content:"DownloadString"; http_uri; nocase; \
  sid:1000072; rev:1; classtype:trojan-activity;)

# Reverse Shell Attempt
alert tcp $HOME_NET any -> any any (msg:"Possible Reverse Shell Detected"; \
  content:"/bin/sh"; \
  sid:1000073; rev:1; classtype:trojan-activity;)
  
# RDP Brute Force
alert tcp any any -> $HOME_NET 3389 (msg:"RDP Brute Force Attempt Detected"; \
  flags:S; threshold:type both, track by_src, count 5, seconds 60; \
  sid:1000080; rev:1; classtype:attempted-admin;)

# SMB EternalBlue Exploit Attempt
alert tcp any any -> $HOME_NET 445 (msg:"SMB EternalBlue Exploit Attempt Detected"; \
  content:"|00 00 00 90|"; depth:4; \
  sid:1000081; rev:1; classtype:attempted-admin;)

# SMB Brute Force
alert tcp any any -> $HOME_NET 445 (msg:"SMB Brute Force Attempt Detected"; \
  threshold:type both, track by_src, count 10, seconds 60; \
  sid:1000082; rev:1; classtype:attempted-admin;)
  
# Tor Network Traffic
alert tcp $HOME_NET any -> any any (msg:"Possible Tor Network Traffic Detected"; \
  content:"torproject.org"; nocase; \
  sid:1000090; rev:1; classtype:policy-violation;)

# Cryptocurrency Mining Traffic
alert tcp $HOME_NET any -> any 3333 (msg:"Possible Cryptocurrency Mining Detected"; \
  content:"stratum+tcp"; nocase; \
  sid:1000091; rev:1; classtype:policy-violation;)

# TELNET Access Attempt
alert tcp any any -> $HOME_NET 23 (msg:"Telnet Access Attempt Detected"; \
  flags:S; \
  sid:1000092; rev:1; classtype:policy-violation;)

# NMAP OS Fingerprinting
alert tcp any any -> $HOME_NET any (msg:"NMAP OS Fingerprint Attempt Detected"; \
  flags:SFPU; \
  sid:1000093; rev:1; classtype:network-scan;)
